{
  "expo": {
    "name": "NextStar",
    "slug": "nextstar",
    "version": "0.1.0",
    "orientation": "portrait",
    "icon": "./assets/brand/nextstar-app-icon.png",
    "userInterfaceStyle": "light",
    "backgroundColor": "#F5F8F5",
    "splash": {
      "image": "./assets/brand/nextstar-wordmark.png",
      "resizeMode": "contain",
      "backgroundColor": "#F7FAF7"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": false,
      "icon": "./assets/brand/nextstar-app-icon.png"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/brand/nextstar-symbol.png",
        "monochromeImage": "./assets/brand/nextstar-symbol.png",
        "backgroundColor": "#F7FAF7"
      },
      "edgeToEdgeEnabled": true
    },
    "androidStatusBar": {
      "barStyle": "dark-content",
      "backgroundColor": "#F7FAF7"
    },
    "androidNavigationBar": {
      "barStyle": "dark-content",
      "backgroundColor": "#F7FAF7"
    },
    "web": {
      "bundler": "metro",
      "favicon": "./assets/brand/nextstar-app-icon.png",
      "name": "NextStar"
    },
    "plugins": [
      "expo-video",
      "expo-system-ui",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#F7FAF7",
          "image": "./assets/brand/nextstar-wordmark.png",
          "imageWidth": 300,
          "resizeMode": "contain"
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Permita que o NextStar acesse seus videos para enviar lances.",
          "cameraPermission": false,
          "microphonePermission": false
        }
      ]
    ]
  }
}
