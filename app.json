{
  "expo": {
    "name": "NextStar",
    "slug": "nextstar",
    "version": "0.1.0",
    "orientation": "portrait",
    "icon": "./assets/nextstar-icon.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/nextstar-logo-cropped.png",
      "resizeMode": "contain",
      "backgroundColor": "#050503"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": false
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/nextstar-icon.png",
        "backgroundColor": "#050503"
      },
      "edgeToEdgeEnabled": true
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      "expo-video",
      [
        "expo-image-picker",
        {
          "photosPermission": "Permita que o NextStar acesse seus videos para enviar lances.",
          "cameraPermission": false,
          "microphonePermission": false
        }
      ]
    ]
  }
}
