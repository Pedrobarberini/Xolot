{
  "expo": {
    "name": "NextStar",
    "slug": "nextstar",
    "scheme": "nextstar",
    "version": "0.1.0",
    "orientation": "portrait",
    "icon": "./assets/brand/nextstar-app-icon.png",
    "userInterfaceStyle": "light",
    "backgroundColor": "#F5F8F5",
    "splash": {
      "image": "./assets/brand/nextstar-wordmark.png",
      "resizeMode": "contain",
      "backgroundColor": "#F7FAF7"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": false,
      "icon": "./assets/brand/nextstar-app-icon.png"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/brand/nextstar-symbol.png",
        "monochromeImage": "./assets/brand/nextstar-symbol.png",
        "backgroundColor": "#F7FAF7"
      },
      "edgeToEdgeEnabled": true
    },
    "androidStatusBar": {
      "barStyle": "dark-content",
      "backgroundColor": "#F7FAF7"
    },
    "androidNavigationBar": {
      "barStyle": "dark-content",
      "backgroundColor": "#F7FAF7"
    },
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./assets/brand/nextstar-app-icon.png",
      "name": "NextStar",
      "shortName": "NextStar",
      "description": "Descubra, envie e avalie talentos do futebol.",
      "themeColor": "#046136",
      "backgroundColor": "#F5F8F5",
      "lang": "pt-BR"
    },
    "plugins": [
      "expo-video",
      "expo-system-ui",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#F7FAF7",
          "image": "./assets/brand/nextstar-wordmark.png",
          "imageWidth": 300,
          "resizeMode": "contain"
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Permita que o NextStar acesse suas fotos e videos para criar publicacoes.",
          "cameraPermission": false,
          "microphonePermission": false
        }
      ],
      [
        "expo-media-library",
        {
          "photosPermission": "Permita que o NextStar mostre a midia mais recente da sua galeria.",
          "savePhotosPermission": false,
          "granularPermissions": [
            "photo",
            "video"
          ]
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Permita que o NextStar use a camera para registrar seus lances.",
          "microphonePermission": "Permita que o NextStar use o microfone durante a gravacao dos seus lances.",
          "recordAudioAndroid": true
        }
      ]
    ]
  }
}
