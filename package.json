{
  "name": "nextstar",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@11.7.0",
  "main": "index.ts",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "test": "node --disable-warning=MODULE_TYPELESS_PACKAGE_JSON --test tests/*.test.mts",
    "web": "expo start --web",
    "build:web": "node scripts/clean-dist.mjs && expo export --platform web --output-dir dist && node scripts/prepare-github-pages.mjs && workbox generateSW workbox-config.js",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "^3.1.1",
    "expo": "~54.0.0",
    "expo-blur": "~15.0.8",
    "expo-crypto": "~15.0.9",
    "expo-image-picker": "~17.0.11",
    "expo-linear-gradient": "~15.0.8",
    "expo-splash-screen": "~31.0.13",
    "expo-system-ui": "~6.0.9",
    "expo-video": "~3.0.16",
    "lucide-react-native": "^1.24.0",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-svg": "15.12.1",
    "react-native-web": "0.21.0"
  },
  "devDependencies": {
    "@types/react": "~19.1.10",
    "typescript": "~5.9.2",
    "workbox-cli": "^7.4.1"
  }
}
